# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Source backups (manual snapshots, not for repo) ───────────
*.backup-*

# ── Native app builds (generated by Capacitor — don't commit) ─
# Anchored with leading slash so only top-level ios/ matches, not app/ios/.
/ios/
/android/

# ── macOS ─────────────────────────────────────────────────────
.DS_Store

# ── Build output ──────────────────────────────────────────────
dist/
.vercel/

# ── Local environment (never commit secrets) ──────────────────
.env
.env.local
.env*.local
.vercel
.claude/worktrees/
.claude/
