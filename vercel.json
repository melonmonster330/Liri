{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "crons": [
    { "path": "/api/sync-catalogue", "schedule": "0 3 * * 5" },
    { "path": "/api/refresh-lyrics?action=lyrics-ready-emails", "schedule": "0 14 * * *" }
  ],
  "redirects": [
    { "source": "/vercel.json",        "destination": "/404", "statusCode": 404 },
    { "source": "/package.json",       "destination": "/404", "statusCode": 404 },
    { "source": "/package-lock.json",  "destination": "/404", "statusCode": 404 },
    { "source": "/.env",               "destination": "/404", "statusCode": 404 },
    { "source": "/.env.:file",         "destination": "/404", "statusCode": 404 },
    { "source": "/.git/:path*",        "destination": "/404", "statusCode": 404 }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "Content-Security-Policy", "value": "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; connect-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app",          "destination": "/app/index.html"   },
    { "source": "/vinyl",        "destination": "/app/vinyl.html"   },
    { "source": "/tv",           "destination": "/tv.html"          },
    { "source": "/library",      "destination": "/app/library.html" },
    { "source": "/stats",        "destination": "/app/stats.html"   },
    { "source": "/privacy",      "destination": "/app/privacy.html" },
    { "source": "/support",      "destination": "/app/support.html" },
    { "source": "/vendor/:file", "destination": "/app/vendor/:file" },
    { "source": "/test",         "destination": "/app/test.html"   },
    { "source": "/admin",        "destination": "/app/admin.html"  }
  ]
}
