{
  "appId": "com.getliri.app",
  "appName": "Liri – Vinyl Lyrics",
  "webDir": "app",
  "backgroundColor": "#080810",
  "ios": {
    "backgroundColor": "#080810"
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a14",
      "showSpinner": false
    },
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "packageClassList": ["KeepAwakePlugin", "NativeAudioPlugin", "ShazamPlugin"]
}
